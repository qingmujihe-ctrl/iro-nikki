rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // profiles are readable by any signed-in user, writable only by the owner
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /follows/{target} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /blocks/{target} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /posts/{date} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == uid;
        // owner can update anything; others may only toggle likes / bump comment count
        allow update: if request.auth != null && (
          request.auth.uid == uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'commentCount'])
        );

        match /comments/{cid} {
          allow read: if request.auth != null;
          allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
          // comment author or post owner can delete
          allow delete: if request.auth != null &&
            (request.auth.uid == resource.data.uid || request.auth.uid == uid);
        }
      }
    }

    match /codes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // 通報: 書き込みのみ（内容の閲覧は運営者がコンソールから行う）
    match /reports/{id} {
      allow create: if request.auth != null && request.resource.data.reporter == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
