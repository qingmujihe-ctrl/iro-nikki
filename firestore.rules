rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // profiles are readable by any signed-in user, writable only by the owner
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /follows/{target} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /posts/{date} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == uid;
        // owner can update anything; others may only toggle likes
        allow update: if request.auth != null && (
          request.auth.uid == uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy'])
        );
      }
    }

    match /codes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }
  }
}
